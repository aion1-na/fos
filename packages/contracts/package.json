{
  "name": "@fw/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/ts/index.js",
  "types": "./dist/ts/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ts/index.d.ts",
      "import": "./dist/ts/index.js"
    },
    "./api": {
      "types": "./dist/api/client.d.ts",
      "import": "./dist/api/client.js"
    },
    "./api/openapi.json": {
      "default": "./dist/api/openapi.json"
    }
  },
  "scripts": {
    "gen": "pnpm run codegen",
    "codegen": "cd ../.. && uv run python tools/codegen/contracts_to_ts.py",
    "gen:api": "cd ../.. && uv run python tools/codegen/openapi_to_ts.py",
    "build": "pnpm run codegen",
    "typecheck": "node -e \"process.exit(0)\"",
    "lint": "node -e \"process.exit(0)\"",
    "fmt": "prettier --check .",
    "test": "pnpm run codegen && node --test tests/ts/*.test.mjs"
  },
  "devDependencies": {
    "prettier": "3.3.3"
  }
}
