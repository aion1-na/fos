{
  "$defs": {
    "DatasetReference": {
      "additionalProperties": false,
      "properties": {
        "canonical_dataset_name": {
          "minLength": 1,
          "pattern": "^[a-z0-9_][a-z0-9_.-]*$",
          "title": "Canonical Dataset Name",
          "type": "string"
        },
        "content_hash": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "canonical_dataset_name",
        "version",
        "content_hash"
      ],
      "title": "DatasetReference",
      "type": "object"
    },
    "EvidenceClaim": {
      "additionalProperties": false,
      "properties": {
        "citation": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Citation"
        },
        "comparator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Comparator"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        },
        "dataset_reference": {
          "anyOf": [
            {
              "$ref": "#/$defs/DatasetReference"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "effect_size": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Effect Size"
        },
        "id": {
          "title": "Id",
          "type": "string"
        },
        "metadata": {
          "additionalProperties": true,
          "title": "Metadata",
          "type": "object"
        },
        "outcome_domain": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Outcome Domain"
        },
        "review_status": {
          "anyOf": [
            {
              "enum": [
                "draft",
                "advisor_reviewed",
                "rejected",
                "superseded"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Status"
        },
        "risk_of_bias": {
          "anyOf": [
            {
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Risk Of Bias"
        },
        "scenario_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Scenario Id"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        },
        "source_uri": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Uri"
        },
        "statement": {
          "title": "Statement",
          "type": "string"
        },
        "target_population": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Target Population"
        },
        "transition_model_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transition Model Id"
        },
        "transportability": {
          "anyOf": [
            {
              "enum": [
                "low",
                "medium",
                "high"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Transportability"
        },
        "treatment": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Treatment"
        },
        "uncertainty": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Uncertainty"
        }
      },
      "required": [
        "id",
        "statement"
      ],
      "title": "EvidenceClaim",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "claims": {
      "items": {
        "$ref": "#/$defs/EvidenceClaim"
      },
      "title": "Claims",
      "type": "array"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "metrics": {
      "additionalProperties": true,
      "title": "Metrics",
      "type": "object"
    },
    "simulation_run_id": {
      "title": "Simulation Run Id",
      "type": "string"
    },
    "status": {
      "enum": [
        "passed",
        "failed",
        "warning"
      ],
      "title": "Status",
      "type": "string"
    },
    "suite_id": {
      "title": "Suite Id",
      "type": "string"
    }
  },
  "required": [
    "id",
    "simulation_run_id",
    "suite_id",
    "status"
  ],
  "title": "ValidationReport",
  "type": "object"
}
