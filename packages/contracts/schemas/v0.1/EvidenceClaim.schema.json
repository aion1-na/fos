{
  "$defs": {
    "DatasetReference": {
      "additionalProperties": false,
      "properties": {
        "canonical_dataset_name": {
          "minLength": 1,
          "pattern": "^[a-z0-9_][a-z0-9_.-]*$",
          "title": "Canonical Dataset Name",
          "type": "string"
        },
        "content_hash": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "canonical_dataset_name",
        "version",
        "content_hash"
      ],
      "title": "DatasetReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "citation": {
      "title": "Citation",
      "type": "string"
    },
    "comparator": {
      "title": "Comparator",
      "type": "string"
    },
    "confidence": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "dataset_reference": {
      "$ref": "#/$defs/DatasetReference"
    },
    "effect_size": {
      "title": "Effect Size",
      "type": "number"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "metadata": {
      "additionalProperties": true,
      "title": "Metadata",
      "type": "object"
    },
    "outcome_domain": {
      "title": "Outcome Domain",
      "type": "string"
    },
    "review_status": {
      "enum": [
        "draft",
        "advisor_reviewed",
        "rejected",
        "superseded"
      ],
      "title": "Review Status",
      "type": "string"
    },
    "risk_of_bias": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "Risk Of Bias",
      "type": "string"
    },
    "scenario_id": {
      "title": "Scenario Id",
      "type": "string"
    },
    "source_id": {
      "title": "Source Id",
      "type": "string"
    },
    "source_uri": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Uri"
    },
    "statement": {
      "title": "Statement",
      "type": "string"
    },
    "target_population": {
      "title": "Target Population",
      "type": "string"
    },
    "transition_model_id": {
      "title": "Transition Model Id",
      "type": "string"
    },
    "transportability": {
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "title": "Transportability",
      "type": "string"
    },
    "treatment": {
      "title": "Treatment",
      "type": "string"
    },
    "uncertainty": {
      "minimum": 0.0,
      "title": "Uncertainty",
      "type": "number"
    }
  },
  "required": [
    "id",
    "scenario_id",
    "transition_model_id",
    "statement",
    "source_id",
    "target_population",
    "treatment",
    "comparator",
    "outcome_domain",
    "effect_size",
    "uncertainty",
    "risk_of_bias",
    "transportability",
    "review_status",
    "citation",
    "dataset_reference"
  ],
  "title": "EvidenceClaim",
  "type": "object"
}
