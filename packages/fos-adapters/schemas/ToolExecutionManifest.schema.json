{
  "$defs": {
    "DatasetReference": {
      "additionalProperties": false,
      "properties": {
        "canonical_dataset_name": {
          "minLength": 1,
          "pattern": "^[a-z0-9_][a-z0-9_.-]*$",
          "title": "Canonical Dataset Name",
          "type": "string"
        },
        "content_hash": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "version": {
          "minLength": 1,
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "canonical_dataset_name",
        "version",
        "content_hash"
      ],
      "title": "DatasetReference",
      "type": "object"
    },
    "ToolArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "adapter_id": {
          "minLength": 1,
          "title": "Adapter Id",
          "type": "string"
        },
        "artifact_id": {
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "artifact_type": {
          "enum": [
            "tool",
            "graph",
            "qualitative"
          ],
          "title": "Artifact Type",
          "type": "string"
        },
        "content_hash": {
          "maxLength": 64,
          "minLength": 64,
          "pattern": "^[a-f0-9]{64}$",
          "title": "Content Hash",
          "type": "string"
        },
        "dataset_references": {
          "items": {
            "$ref": "#/$defs/DatasetReference"
          },
          "minItems": 1,
          "title": "Dataset References",
          "type": "array"
        },
        "notes": {
          "default": "",
          "title": "Notes",
          "type": "string"
        },
        "uri": {
          "minLength": 1,
          "title": "Uri",
          "type": "string"
        },
        "validated_for_causal_effects": {
          "default": false,
          "title": "Validated For Causal Effects",
          "type": "boolean"
        }
      },
      "required": [
        "artifact_id",
        "adapter_id",
        "artifact_type",
        "uri",
        "content_hash",
        "dataset_references"
      ],
      "title": "ToolArtifactReference",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "adapter_id": {
      "minLength": 1,
      "title": "Adapter Id",
      "type": "string"
    },
    "adapter_version": {
      "minLength": 1,
      "title": "Adapter Version",
      "type": "string"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/ToolArtifactReference"
      },
      "minItems": 1,
      "title": "Artifacts",
      "type": "array"
    },
    "capabilities": {
      "items": {
        "enum": [
          "qualitative_interaction",
          "cognition_trace",
          "graph_layout",
          "graph_render",
          "network_analysis",
          "causal_estimation"
        ],
        "type": "string"
      },
      "title": "Capabilities",
      "type": "array"
    },
    "executed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Executed At"
    },
    "input_dataset_references": {
      "items": {
        "$ref": "#/$defs/DatasetReference"
      },
      "minItems": 1,
      "title": "Input Dataset References",
      "type": "array"
    },
    "qualitative_only": {
      "default": true,
      "title": "Qualitative Only",
      "type": "boolean"
    },
    "run_id": {
      "minLength": 1,
      "title": "Run Id",
      "type": "string"
    },
    "trust_policy": {
      "enum": [
        "allowed",
        "quarantined",
        "blocked",
        "research_only"
      ],
      "title": "Trust Policy",
      "type": "string"
    }
  },
  "required": [
    "run_id",
    "adapter_id",
    "adapter_version",
    "trust_policy",
    "capabilities",
    "input_dataset_references",
    "artifacts"
  ],
  "title": "ToolExecutionManifest",
  "type": "object"
}
