{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecureAnalysisManifest",
  "type": "object",
  "required": [
    "project_id",
    "environment",
    "restricted_dataset_name",
    "access_status",
    "raw_restricted_data_in_fos_allowed",
    "code_ref",
    "code_hash",
    "environment_ref",
    "environment_hash",
    "intended_outputs",
    "owner",
    "timeline"
  ],
  "properties": {
    "project_id": { "type": "string", "minLength": 1 },
    "environment": {
      "enum": ["census_rdc", "external_secure_enclave", "provider_clean_room"]
    },
    "restricted_dataset_name": { "type": "string", "minLength": 1 },
    "access_status": { "enum": ["request_status_stub", "approved", "rejected"] },
    "raw_restricted_data_in_fos_allowed": { "type": "boolean", "default": false },
    "raw_restricted_data_uri": { "type": ["string", "null"] },
    "code_ref": { "type": "string", "minLength": 1 },
    "code_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "environment_ref": { "type": "string", "minLength": 1 },
    "environment_hash": { "type": "string", "minLength": 64, "maxLength": 64 },
    "intended_outputs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "owner": { "type": "string", "minLength": 1 },
    "timeline": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
